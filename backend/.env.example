# Backend Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_generate_a_secure_random_256bit_key

# ─── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── Database ─────────────────────────────────────────────────────────────────
# Leave empty to use default SQLite (recommended for local dev)
# Set to a PostgreSQL DSN for production:
#   DATABASE_URL=postgresql://user:password@localhost:5432/movie_recommender
DATABASE_URL=

# ─── Server Config ────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000

# ─── Redis Cache ──────────────────────────────────────────────────────────────
# Leave empty to fall back to a local in-memory TTL cache
REDIS_URL=

# ─── TMDB (The Movie Database) API ───────────────────────────────────────────
# Ex: TMDB_API_KEY=your_key or TMDB_ACCESS_TOKEN=your_token
# Leave blank to bypass poster enrichment
TMDB_API_KEY=
TMDB_ACCESS_TOKEN=
