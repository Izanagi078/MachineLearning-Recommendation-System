# Backend Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_generate_a_secure_random_256bit_key

# ─── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── Database ─────────────────────────────────────────────────────────────────
# Leave empty to use default SQLite (recommended for local dev)
# Set to a PostgreSQL DSN for production:
#   DATABASE_URL=postgresql://user:password@localhost:5432/movie_recommender
DATABASE_URL=
